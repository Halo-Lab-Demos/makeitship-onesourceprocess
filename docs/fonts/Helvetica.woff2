    <script async>
        jQuery(document).ready(function(){
            console.log('intercom init');
            setTimeout( () => {
                // We pre-filled your app ID in the widget URL: 'https://widget.intercom.io/widget/thn4a13o'
                var w = window;
                var ic = w.Intercom;
